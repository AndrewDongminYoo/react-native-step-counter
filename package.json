{
  "name": "@dongminyu/react-native-step-counter",
  "version": "0.3.1",
  "description": "This library provides an interface for tracking the number of steps taken by the user in a React Native app.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace @dongminyu/react-native-step-counter-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build example/ios/Pods lib",
    "test": "jest --runInBand --no-watchman",
    "prepare": "bob build",
    "typecheck": "tsc",
    "watchman-reset": "watchman watch-del $PWD && watchman watch-project $PWD"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewDongminYoo/react-native-step-counter.git"
  },
  "author": "Dongmin, Yoo <ydm2790@gmail.com> (https://github.com/AndrewDongminYoo)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AndrewDongminYoo/react-native-step-counter/issues"
  },
  "homepage": "https://github.com/AndrewDongminYoo/react-native-step-counter#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@release-it/conventional-changelog": "^11.0.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/babel__core": "^7.20.5",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.15",
    "@types/react-test-renderer": "^19.1.0",
    "del-cli": "^7.0.0",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "react-test-renderer": "19.2.3",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "basic-ftp": "5.3.1",
    "brace-expansion@npm:^1.1.7": "npm:1.1.13",
    "brace-expansion@npm:^2.0.1": "npm:2.0.3",
    "brace-expansion@npm:^5.0.2": "npm:5.0.6",
    "defu@npm:^6.1.4": "npm:6.1.7",
    "fast-xml-parser": "5.7.0",
    "handlebars@npm:^4.7.7": "npm:4.7.9",
    "ip-address@npm:^10.0.1": "npm:10.1.1",
    "minimatch@npm:^10.2.1": "npm:10.2.3",
    "minimatch@npm:^3.0.4": "npm:3.1.4",
    "minimatch@npm:^3.1.1": "npm:3.1.4",
    "minimatch@npm:^9.0.4": "npm:9.0.7",
    "picomatch@npm:^2.0.4": "npm:2.3.2",
    "picomatch@npm:^2.2.3": "npm:2.3.2",
    "picomatch@npm:^2.3.1": "npm:2.3.2",
    "picomatch@npm:^4.0.3": "npm:4.0.4",
    "tar": "7.5.13",
    "yaml@npm:^2.2.1": "npm:2.8.3",
    "yaml@npm:^2.6.1": "npm:2.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.85.3"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "StepCounterSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.stepcounter"
    }
  }
}
